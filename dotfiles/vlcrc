[qt]
qt-opacity=0.950000
qt-fs-opacity=1.000000
qt-dark-palette=1
qt-privacy-ask=0

[skins2]
skins2-transparency=1

[freetype]
freetype-font=Arial
#freetype-fontsize=0
#freetype-rel-fontsize=0
#freetype-color=16777215
#freetype-bold=0
freetype-outline-thickness=6
freetype-shadow-opacity=0

[core]
volume-save=0
disable-screensaver=1
mouse-hide-timeout=1000
video-title-show=0
snapshot-path=~
snapshot-format=png
snapshot-preview=1
sub-track=0
hotkeys-y-wheel-mode=-1
hotkeys-x-wheel-mode=-1
